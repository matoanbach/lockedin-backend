APP_NAME=LockdIn Backend
APP_VERSION=0.1.0
DEBUG=true
CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Copy to backend/.env and use with:
# docker compose --env-file backend/.env up -d
# docker compose -f backend/docker-compose.yml --env-file backend/.env up -d

# Docker/backend runtime
BACKEND_PORT=8000
BACKEND_CONTAINER_PORT=8000
BIND=0.0.0.0:8000
WORKERS=1
WORKER_CLASS=uvicorn.workers.UvicornWorker
LOGLEVEL=info

# Postgres container exposed on host port 5433.
POSTGRES_DB=lockedin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Local non-Docker backend connection URL.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/lockedin

# Dockerized backend connecting to the separately-run database stack.
DOCKER_DATABASE_URL=postgresql+psycopg://postgres:postgres@host.docker.internal:5433/lockedin
