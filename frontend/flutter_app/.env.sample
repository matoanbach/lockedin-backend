# Frontend API base URL override.
#
# Copy this file to `.env` and use the same value with Flutter's
# `--dart-define` or `--dart-define-from-file` workflow.
#
# Physical Android phone on the same Wi-Fi as the development computer.
# Replace the example address with the computer's current Wi-Fi IPv4 address.
LOCKDIN_API_BASE_URL=http://192.168.2.44:8000

# Android emulator talking to a backend on your host machine:
# LOCKDIN_API_BASE_URL=http://10.0.2.2:8000

# Desktop/web talking to a backend on the same machine:
# LOCKDIN_API_BASE_URL=http://127.0.0.1:8000

# Example for a deployed backend:
# LOCKDIN_API_BASE_URL=https://api.example.com
